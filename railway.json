{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "sh -c 'node openclaw.mjs gateway run --bind lan --port $PORT --allow-unconfigured'",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE"
  },
  "variables": {
    "OPENCLAW__AGENTS__DEFAULTS__AGENT_RUNTIME__ID": "pi",
    "OPENCLAW__AGENTS__DEFAULTS__MODEL__PROVIDER": "google-ai-studio",
    "OPENCLAW__AGENTS__DEFAULTS__MODEL__MODEL": "gemini-2.0-flash",
    "OPENCLAW__EXTENSIONS__CODEX__DISCOVERY__ENABLED": "false",
    "OPENCLAW__CHANNELS__TELEGRAM__DM_POLICY": "open",
    "OPENCLAW__CHANNELS__TELEGRAM__ALLOW_FROM": "984052013"
  }
}
