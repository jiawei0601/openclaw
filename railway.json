{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "node openclaw.mjs gateway run --bind lan --port $PORT --allow-unconfigured",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE"
  }
}
