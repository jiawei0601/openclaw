{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "sh -c 'echo \"$GOOGLE_DRIVE_CREDENTIALS_JSON\" > /tmp/google-drive-key.json && node openclaw.mjs gateway run --bind lan --port $PORT --allow-unconfigured'",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE"
  },
  "variables": {
    "OPENCLAW__AGENTS__DEFAULTS__AGENT_RUNTIME__ID": "pi",
    "OPENCLAW__AGENTS__DEFAULTS__MODEL__PROVIDER": "google",
    "OPENCLAW__AGENTS__DEFAULTS__MODEL__MODEL": "gemini-2.5-flash",
    "OPENCLAW__EXTENSIONS__CODEX__DISCOVERY__ENABLED": "false",
    "OPENCLAW__CHANNELS__TELEGRAM__DM_POLICY": "open",
    "OPENCLAW__CHANNELS__TELEGRAM__ALLOW_FROM": "984052013",
    "OPENCLAW__AGENTS__DEFAULTS__TIMEOUT_SECONDS": "180",
    "OPENCLAW__MCP__SERVERS__GOOGLE_DRIVE__COMMAND": "npx",
    "OPENCLAW__MCP__SERVERS__GOOGLE_DRIVE__ARGS": "-y,@modelcontextprotocol/server-google-drive",
    "OPENCLAW__MCP__SERVERS__GOOGLE_DRIVE__ENV__GOOGLE_APPLICATION_CREDENTIALS": "/tmp/google-drive-key.json"
  }
}
