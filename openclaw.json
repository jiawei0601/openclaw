{
  "agents": {
    "defaults": {
      "model": "google/gemini-2.5-flash",
      "agentRuntime": {
        "id": "pi"
      },
      "timeoutSeconds": 180
    }
  },
  "mcp": {
    "servers": {
      "google_drive": {
        "command": "mcp-server-gdrive",
        "args": [],
        "env": {
          "GOOGLE_APPLICATION_CREDENTIALS": "/tmp/google-drive-key.json"
        },
        "type": "stdio",
        "description": "Access and manage files in Google Drive, including reading, creating, and editing documents."
      }
    }
  },
  "channels": {
    "telegram": {
      "dmPolicy": "open",
      "allowFrom": ["984052013"]
    }
  }
}
