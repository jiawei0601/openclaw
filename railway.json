{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "node /app/scripts/start.mjs",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  },
  "variables": {
    "OPENCLAW__EXTENSIONS__CODEX__DISCOVERY__ENABLED": "false"
  }
}
