# =============================================
# 小A 台股自動交易機器人 — Railway 環境變數範本
# =============================================
# Railway 部署：在 Variables 頁面逐一填入
# 本地測試：複製此檔為 .env 並填入實際值（勿 commit .env）

# ── Telegram Bot ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── AI 模型（擇一填入）────────────────────────────────────────────
GEMINI_API_KEY=

# 可選：覆寫預設模型（預設 google/gemini-2.5-flash-preview）
# AGENT_MODEL=google/gemini-2.5-flash-preview

# ── 富果行情查詢 ──────────────────────────────────────────────────
FUGLE_API_KEY=

# ── 台新證券下單 ──────────────────────────────────────────────────
TAISHIN_PERSONAL_ID=
TAISHIN_PASSWORD=
TAISHIN_CERT=
TAISHIN_CERT_PASS=
# 1 = 模擬模式（測試用），0 = 真實交易
TAISHIN_PAPER=1

# ── 憑證轉換指令（PowerShell）────────────────────────────────────
# [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\path\to\憑證.pfx"))
# 輸出的單行字串貼入 TAISHIN_CERT
